{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.omni.dev/xiuxian.runtime.route_trace.v1.schema.json",
  "title": "Xiuxian Runtime Route Trace v1",
  "description": "Turn-level route trace contract for Omega governance and observability.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "turn_id",
    "selected_route",
    "confidence",
    "risk_level",
    "tool_trust_class"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0
    },
    "selected_route": {
      "type": "string",
      "enum": ["react", "graph"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "tool_trust_class": {
      "type": "string",
      "enum": ["evidence", "verification", "other"]
    },
    "fallback_applied": {
      "type": "boolean"
    },
    "fallback_policy": {
      "type": "string",
      "enum": ["retry_react", "switch_to_graph", "abort"]
    },
    "tool_chain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0.0
    },
    "failure_taxonomy": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "injection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blocks_used": {
          "type": "integer",
          "minimum": 0
        },
        "chars_injected": {
          "type": "integer",
          "minimum": 0
        },
        "dropped_by_budget": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_mode": {
      "type": "string",
      "enum": ["graph", "omega"]
    },
    "graph_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "id", "kind", "attempt", "latency_ms", "status"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "prepare_injection_context",
              "invoke_graph_tool",
              "evaluate_fallback"
            ]
          },
          "attempt": {
            "type": "integer",
            "minimum": 0
          },
          "latency_ms": {
            "type": "number",
            "minimum": 0.0
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "failure_reason": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "fallback_action": {
            "type": "string",
            "enum": ["abort", "retry_bridge_without_metadata", "route_to_react"]
          }
        }
      }
    }
  }
}
